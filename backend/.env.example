# OKX Auto Trader Environment Variables

# Application
APP_NAME=OKX Auto Trader
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/okx_trader.db

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Exchange
DEFAULT_EXCHANGE=okx
OKX_API_BASE_URL=https://www.okx.com

# Risk Control
MAX_POSITION_PERCENT=10.0
DEFAULT_LEVERAGE=3
STOP_LOSS_PERCENT=5.0
MAX_DAILY_LOSS=15.0
CIRCUIT_BREAKER_COUNT=3

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
